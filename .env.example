# CTIE environment configuration
# Copy this file to .env and fill in your own keys.

# -----------------------------------------------------------------------------
# Composio toolkit enrichment (optional but recommended)
# -----------------------------------------------------------------------------
# Free tier includes ~20K tool calls/month.
# Used only for toolkit catalog lookups and GitHub toolkit actions.
# Leave blank to skip Composio enrichment.
COMPOSIO_API_KEY=your_composio_api_key

# -----------------------------------------------------------------------------
# LLM provider selection
# -----------------------------------------------------------------------------
# AWS Bedrock is now the primary reasoning provider.
# Azure OpenAI is available as a fallback.
LLM_PROVIDER=bedrock
# Options: azure_openai, bedrock

# -----------------------------------------------------------------------------
# Primary LLM: AWS Bedrock
# Option 1: Use Bearer Token (recommended for short-lived access)
# Option 2: Use traditional AWS credentials (AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY)
# Only one method is required!
# -----------------------------------------------------------------------------
# Option 1: Bearer Token (short-lived)
AWS_BEARER_TOKEN_BEDROCK=your_bedrock_bearer_token
# Option 2: Traditional AWS credentials (if not using Bearer token)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_SESSION_TOKEN=your_aws_session_token
AWS_REGION=your_aws_region
BEDROCK_MODEL=your_bedrock_model

# -----------------------------------------------------------------------------
# Fallback LLM: Azure OpenAI (optional)
# Only used if Bedrock fails.
# Leave blank to disable Azure OpenAI fallback.
# -----------------------------------------------------------------------------
# AZURE_OPENAI_API_KEY=your_azure_openai_api_key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4
# AZURE_OPENAI_API_VERSION=2024-12-01-preview

# -----------------------------------------------------------------------------
# Pipeline behavior
# -----------------------------------------------------------------------------
# Max parallel apps processed at once.
CTIE_CONCURRENCY=5

# SQLite database path for state, cache, and evidence (ignored by git).
CTIE_DB_PATH=outputs/ctie.db

# Number of retries for transient failures (network, rate limits, etc.).
CTIE_MAX_RETRIES=3

# Set to "true" to force a fresh run even if a previous run exists.
CTIE_FORCE_FRESH=False

# HTTP fetch timeout in seconds.
CTIE_FETCH_TIMEOUT=30

# Max document size in bytes to store.
CTIE_MAX_FETCH_SIZE=2000000

# Number of top search results to fetch per app.
CTIE_DOCUMENTS_PER_APP=5

# Search rate limit in queries per minute (for DuckDuckGo).
CTIE_SEARCH_RATE_LIMIT_QPS=10

# Optional Google PSE fallback
# GOOGLE_PSE_API_KEY=your_google_pse_api_key
# GOOGLE_PSE_ENGINE_ID=your_google_pse_engine_id
